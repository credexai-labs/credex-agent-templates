# CredexAI Agent Templates - Environment Variables
# Copy this file to .env and fill in the values

# CredexAI API Configuration
CREDEX_API_KEY=your_credex_api_key_here
CREDEX_BASE_URL=https://credexai.live/api

# OpenAI (for agent LLM calls)
OPENAI_API_KEY=your_openai_api_key_here

# XRPL (optional - leave empty for simulation mode)
XRPL_WALLET_SEED=
XRPL_NODE_URL=wss://xrplcluster.com
